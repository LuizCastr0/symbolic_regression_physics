import torch
import torch.nn as nn
import segmentation_models_pytorch as smp
from torch.utils.data import DataLoader, Dataset
import albumentations as A
import cv2
import numpy as np
import os
from glob import glob
from tqdm import tqdm

# --- FUNÇÃO DE MAPEAMENTO (SUA LÓGICA) ---
def mapear_dados():
    base_path = r"C:\projeto\data\Train"
    pastas_img = ['GID-img-1', 'GID-img-2', 'GID-img-3', 'GID-img-4']
    pasta_label = 'GID-label'
    pares = []
    labels = glob(os.path.join(base_path, pasta_label, "*.png"))
    for path_label in labels:
        id_comum = os.path.basename(path_label).replace(".png", "")
        for p_img in pastas_img:
            caminho_img = os.path.join(base_path, p_img, id_comum + ".jpg")
            if os.path.exists(caminho_img):
                pares.append((caminho_img, path_label))
                break
    return pares

# --- FILTRO ANTI-ZERO (PARA A IA ENXERGAR ÁGUA) ---
def filtrar_so_com_agua(pares_brutos):
    print(" Escaneando imagens que possuem água (valor 178)...")
    uteis = []
    for img, msk in tqdm(pares_brutos[:1000]): # Testando nas primeiras 1000 para ser rápido
        m = cv2.imread(msk, 0)
        if 178 in m: uteis.append((img, msk))
    return uteis

class WaterDatasetPro(Dataset):
    def __init__(self, pares):
        self.pares = pares
        self.transform = A.Compose([
            A.Resize(256, 256),
            A.HorizontalFlip(p=0.5),
            A.Normalize(mean=(0.485, 0.456, 0.406), std=(0.229, 0.224, 0.225)),
        ])
    def __len__(self): return len(self.pares)
    def __getitem__(self, idx):
        img = cv2.imread(self.pares[idx][0])
        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)
        mask = cv2.imread(self.pares[idx][1], 0)
        label = np.zeros_like(mask, dtype=np.int64)
        label[mask == 178] = 1 
        aug = self.transform(image=img, mask=label)
        return torch.tensor(aug['image'].transpose(2, 0, 1), dtype=torch.float32), \
               torch.tensor(aug['mask'], dtype=torch.long)

# --- EXECUÇÃO ---
if __name__ == "__main__":
    DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    
    # 1. Preparar Dados
    todos_pares = mapear_dados()
    pares_filtrados = filtrar_so_com_agua(todos_pares)
    
    loader = DataLoader(WaterDatasetPro(pares_filtrados), batch_size=8, shuffle=True)
    
    # 2. Modelo Profissional (Unet++)
    model = smp.UnetPlusPlus(encoder_name="resnet34", classes=2).to(DEVICE)
    
    # 3. Perda Híbrida (Impede o erro zero)
    criterion_dice = smp.losses.DiceLoss(mode='multiclass')
    criterion_ce = nn.CrossEntropyLoss()
    optimizer = torch.optim.AdamW(model.parameters(), lr=1e-4)

    print(f"🚀 Treinando com {len(pares_filtrados)} imagens que possuem água...")
    for epoch in range(5):
        model.train()
        loop = tqdm(loader)
        for imgs, masks in loop:
            imgs, masks = imgs.to(DEVICE), masks.to(DEVICE)
            outputs = model(imgs)
            loss = criterion_dice(outputs, masks) + criterion_ce(outputs, masks)
            
            optimizer.zero_grad()
            loss.backward()
            optimizer.step()
            loop.set_postfix(loss=f"{loss.item():.4f}")
        
        torch.save(model.state_dict(), f"modelo_v4_e{epoch+1}.pth")
import torch
import segmentation_models_pytorch as smp
import cv2
import numpy as np
import folium
from folium import plugins

# --- CONFIGURAÇÕES ---
DEVICE = torch.device("cuda" if torch.cuda.is_available() else "cpu")
PATH_MODELO = r"C:\projeto\notebooks\modelo_agua_rgb_final.pth"
# Escolha uma imagem da pasta de teste (que termina em .png)
PATH_IMG_TESTE = r"C:\projeto\data\Train\GID-img-2\GF2_PMS1__L1A0001680853-MSS1_0_512_size512.jpg" 

# 1. Carregar o Modelo (mesma arquitetura do treino)
model = smp.UnetPlusPlus(encoder_name="resnet34", in_channels=3, classes=1).to(DEVICE)
model.load_state_dict(torch.load(PATH_MODELO))
model.eval()

# 2. Processar a Imagem
img_bgr = cv2.imread(PATH_IMG_TESTE)
img_rgb = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2RGB)
h_ori, w_ori, _ = img_rgb.shape

# Redimensionar para o tamanho que a IA foi treinada
img_input = cv2.resize(img_rgb, (256, 256))
img_norm = (img_input / 255.0 - [0.485, 0.456, 0.406]) / [0.229, 0.224, 0.225]
img_tensor = torch.tensor(img_norm.transpose(2, 0, 1), dtype=torch.float32).unsqueeze(0).to(DEVICE)

# 3. Predição
with torch.no_grad():
    output = model(img_tensor)
    # Como usamos classes=1, passamos um sigmoid para ter probabilidade entre 0 e 1
    prob = torch.sigmoid(output).squeeze().cpu().numpy()
    mask_pred = (prob > 0.5).astype(np.uint8) # 0.5 é a sensibilidade

# 4. Criar o Mapa Interativo (Folium)
# Como não temos as coordenadas reais (devido ao arquivo .cfg binário), 
# vamos centralizar em um ponto padrão ou apenas visualizar a máscara.
m = folium.Map(location=[-23.55, -46.63], zoom_start=12) # Local genérico

# Converter a máscara para uma imagem que o Folium aceite (Overlay)
# Criamos uma imagem RGBA onde a água é azul e o resto é transparente
mask_resized = cv2.resize(mask_pred, (w_ori, h_ori), interpolation=cv2.INTER_NEAREST)
rgba_mask = np.zeros((h_ori, w_ori, 4), dtype=np.uint8)
rgba_mask[mask_resized == 1] = [0, 0, 255, 150] # Azul com transparência

# Adicionar a imagem original e a máscara ao mapa
folium.raster_layers.ImageOverlay(
    image=img_rgb,
    bounds=[[0, 0], [100, 100]], # Coordenadas arbitrárias para visualização
    name='Imagem de Satélite'
).add_to(m)

folium.raster_layers.ImageOverlay(
    image=rgba_mask,
    bounds=[[0, 0], [100, 100]],
    name='Água Detectada pela IA'
).add_to(m)

folium.LayerControl().add_to(m)
m.save("resultado_teste_interativo.html")

print("✅ Mapa gerado com sucesso! Abra o arquivo 'resultado_teste_interativo.html' no seu navegador.")
